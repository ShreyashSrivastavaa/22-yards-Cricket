generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Player {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  team         String?
  innings      Int      @default(0)
  runs         Int      @default(0)
  balls        Int      @default(0)
  strikeRate   Float    @default(0) @map("strike_rate")
  average      Float    @default(0)
  fours        Int      @default(0)
  sixes        Int      @default(0)
  wickets      Int      @default(0)
  economy      Float    @default(0)
  bowlingBalls Int      @default(0) @map("bowling_balls")
  bowlingRuns  Int      @default(0) @map("bowling_runs")
  fantasyScore Int      @default(0) @map("fantasy_score")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("players")
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String
  color     String   @default("#FFD700")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("teams")
}

model Match {
  id        String   @id
  season    String?
  date      String?
  venue     String?
  team1     String?
  team2     String?
  winner    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("matches")
}

model PointsTable {
  id     Int      @id @default(autoincrement())
  season String
  team   String
  played Int      @default(0)
  won    Int      @default(0)
  lost   Int      @default(0)
  points Int      @default(0)
  last5  String[] @default([])
  rank   Int      @default(0)

  @@unique([season, team])
  @@map("points_table")
}

model InternationalMatch {
  id         String   @id
  tournament String
  season     String
  date       String?
  venue      String?
  team1      String?
  team2      String?
  winner     String?
  format     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("international_matches")
}

model PlayerTournamentStats {
  id           Int     @id @default(autoincrement())
  playerName   String  @map("player_name")
  tournament   String
  season       String
  team         String?
  runs         Int     @default(0)
  balls        Int     @default(0)
  strikeRate   Float   @default(0) @map("strike_rate")
  fours        Int     @default(0)
  sixes        Int     @default(0)
  wickets      Int     @default(0)
  economy      Float   @default(0)
  innings      Int     @default(0)
  fantasyScore Int     @default(0) @map("fantasy_score")

  @@unique([playerName, tournament, season])
  @@map("player_tournament_stats")
}

model AuctionRecord {
  id          Int     @id @default(autoincrement())
  playerName  String  @map("player_name")
  year        String?
  team        String?
  basePrice   Float?  @map("base_price")
  soldPrice   Float?  @map("sold_price")
  nationality String?
  role        String?

  @@map("auction_records")
}
